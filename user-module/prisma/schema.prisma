generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String              @id @default(uuid())
  phone             String              @unique
  name              String?
  email             String?
  panNumber         String?
  aadhaarNumber     String?
  isKycDone         Boolean             @default(false)
  kycStatus         String              @default("PENDING")
  isActive          Boolean             @default(true)

  // Role field — required by business module JWT and RBAC
  // Valid values: CUSTOMER | AGENT
  role              String              @default("CUSTOMER")

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  kycDetail         KycDetail?
  eNachMandate      ENachMandate?
  blacklistedTokens TokenBlacklist[]
  loan_applications loan_applications[]

  @@map("users")
}

model agents {
  id        String   @id
  name      String
  phone     String   @unique
  email     String?
  gstNumber String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model audit_logs {
  id                String            @id
  applicationId     String
  action            String
  performedBy       String
  details           String?
  createdAt         DateTime          @default(now())
  loan_applications loan_applications @relation(fields: [applicationId], references: [id])
}

model emi_schedule {
  id                String            @id
  applicationId     String
  instalmentNo      Int
  dueDate           DateTime
  amount            Float
  status            String            @default("PENDING")
  retryCount        Int               @default(0)
  paidAt            DateTime?
  createdAt         DateTime          @default(now())
  loan_applications loan_applications @relation(fields: [applicationId], references: [id])
}

model loan_applications {
  id                 String         @id
  userId             String
  productType        String
  amount             Float
  tenure             Int
  annualInterestRate Float          @default(18)
  merchantId         String?
  status             String         @default("PENDING")
  cibilScore         Int?
  fraudScore         Float?
  rejectionReason    String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime
  audit_logs         audit_logs[]
  emi_schedule       emi_schedule[]
  users              User           @relation(fields: [userId], references: [id])
  payments           payments[]
}

model payments {
  id                String            @id
  applicationId     String
  amount            Float
  type              String
  status            String            @default("PENDING")
  razorpayId        String?
  createdAt         DateTime          @default(now())
  loan_applications loan_applications @relation(fields: [applicationId], references: [id])
}

model OtpVerification {
  id        String   @id @default(uuid())
  phone     String
  otp       String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone, createdAt])
  @@map("otp_verifications")
}

model KycDetail {
  id              String   @id @default(uuid())
  userId          String   @unique
  panNumber       String?
  panVerified     Boolean  @default(false)
  aadhaarNumber   String?
  aadhaarVerified Boolean  @default(false)
  selfieVerified  Boolean  @default(false)
  eSignStatus     String   @default("PENDING")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])

  @@map("kyc_details")
}

model ENachMandate {
  id        String   @id @default(uuid())
  userId    String   @unique
  mandateId String   @unique
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@map("enach_mandates")
}

model TokenBlacklist {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("token_blacklist")
}