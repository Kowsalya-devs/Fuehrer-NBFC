PORT=3000
NODE_ENV="development"
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@YOUR_HOST:5432/fuehrer_dev"
JWT_SECRET="replace_with_a_secure_jwt_secret"
JWT_EXPIRES_IN="7d"
ENCRYPTION_KEY="replace_with_32_byte_base64_key"
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_OTP_TEMPLATE_ID=your_dlt_template_id

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/feuhrer_db

# JWT
JWT_SECRET=your_64_char_hex_secret_here
JWT_EXPIRES_IN=7d

# Encryption — must be 64 hex chars (32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_key_here

# SMS — required in production only
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_OTP_TEMPLATE_ID=your_dlt_template_id

# App
NODE_ENV=development
PORT=3000
